    "multer": "^2.1.1",
    "mysql2": "^3.22.5",
    "opossum": "^9.0.0",
    "p-limit": "^7.3.0",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "path-to-regexp": "^8.4.2",
    "pdf-parse": "^2.4.5",
    "prom-client": "^15.1.3",
    "reflect-metadata": "^0.2.2",
    "request-ip": "^3.3.0",
    "rimraf": "^5.0.1",
    "rxjs": "^7.8.1",
    "stacktrace-js": "^2.0.2",
    "swagger-ui-express": "^5.0.1",
    "ts-enum-util": "^4.0.2",
    "typeorm": "^0.3.30",
    "uuid": "^9.0.0",
    "xlsx": "^0.18.5"
